  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧹 Limpieza y Transformación de Datos"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Eliminar duplicados si existen\n",
    "antes = len(df)\n",
    "df = df.drop_duplicates()\n",
    "print(f'Duplicados eliminados: {antes - len(df)}')\n",
    "\n",
    "# Limpiar espacios en columnas de texto\n",
    "for col in df.select_dtypes(include='object').columns:\n",
    "    df[col] = df[col].str.strip()\n",
    "\n",
    "# Crear columna de grupo de resultado (KO/TKO vs Decisión vs Otros)\n",
    "def clasificar_resultado(r):\n",
    "    if r in ['KO', 'TKO']:\n",
    "        return 'KO / TKO'\n",
    "    elif 'Decisión' in str(r):\n",
    "        return 'Decisión'\n",
    "    else:\n",
    "        return 'Otro'\n",
    "\n",
    "df['grupo_resultado'] = df['resultado'].apply(clasificar_resultado)\n",
    "\n",
    "# Ordenar décadas correctamente\n",
    "orden_decadas = ['1920s','1930s','1940s','1950s','1960s','1970s','1980s','1990s','2000s','2010s','2020s']\n",
    "df['decada'] = pd.Categorical(df['decada'], categories=orden_decadas, ordered=True)\n",
    "\n",
    "print('✅ Limpieza completada')\n",
    "print(f'Filas finales: {len(df)}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 📊 Análisis Exploratorio de Datos (EDA)\n",
    "\n",
    "---\n",
    "### Pregunta 1: ¿Cómo evolucionó la cantidad de combates a lo largo del tiempo?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "combates_por_decada = df.groupby('decada', observed=True).size().reset_index(name='cantidad')\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(13, 5))\n",
    "bars = ax.bar(combates_por_decada['decada'], combates_por_decada['cantidad'],\n",
    "              color=COLORS[0], edgecolor='white', linewidth=0.8, alpha=0.9)\n",
    "\n",
    "for bar in bars:\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 30,\n",
    "            f'{int(bar.get_height()):,}', ha='center', va='bottom', fontsize=9, color='#2C3E50')\n",
    "\n",
    "ax.set_title('Cantidad de Combates de Boxeo por Década', fontsize=15, fontweight='bold', pad=15)\n",
    "ax.set_xlabel('Década', fontsize=12)\n",
    "ax.set_ylabel('N° de Combates', fontsize=12)\n",
    "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{int(x):,}'))\n",
    "plt.tight_layout()\n",
    "plt.savefig('viz_1_combates_por_decada.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('\\n📌 Insight: La actividad boxística creció sostenidamente hasta los años 1990s–2000s, con un leve descenso en la última década.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Pregunta 2: ¿Cuáles son las modalidades de victoria más frecuentes?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "resultado_counts = df['resultado'].value_counts().reset_index()\n",
    "resultado_counts.columns = ['resultado', 'cantidad']\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Pie chart\n",
    "wedges, texts, autotexts = ax1.pie(\n",
    "    resultado_counts['cantidad'],\n",
    "    labels=resultado_counts['resultado'],\n",
    "    autopct='%1.1f%%',\n",
    "    colors=COLORS[:len(resultado_counts)],\n",
    "    startangle=90,\n",
    "    pctdistance=0.8\n",
    ")\n",
    "for t in autotexts:\n",
    "    t.set_fontsize(9)\n",
    "ax1.set_title('Distribución Global de Resultados', fontsize=13, fontweight='bold')\n",
    "\n",
    "# Evolución de KO/TKO vs Decisión por década\n",
    "pivot = df.groupby(['decada','grupo_resultado'], observed=True).size().unstack(fill_value=0)\n",
    "pivot_pct = pivot.div(pivot.sum(axis=1), axis=0) * 100\n",
    "\n",
    "pivot_pct.plot(kind='bar', stacked=True, ax=ax2,\n",
    "               color=['#C0392B','#2980B9','#F39C12'], edgecolor='white')\n",
    "ax2.set_title('Evolución del Tipo de Victoria por Década (%)', fontsize=13, fontweight='bold')\n",
    "ax2.set_xlabel('Década')\n",
    "ax2.set_ylabel('% de Combates')\n",
    "ax2.tick_params(axis='x', rotation=45)\n",
    "ax2.legend(title='Tipo', loc='upper right', fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('viz_2_tipos_resultado.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('\\n📌 Insight: Los KO/TKO han disminuido progresivamente como porcentaje del total de combates, dando paso a más victorias por decisión.')"
   ]
  },
  {
